pipeline {
    agent any

    environment {
        COMPOSE_FILE = 'docker-compose.dev.yml'
        SERVICE_NAME = 'frontend-dev'
        FRONTEND_DIR = 'frontend'
    }

    options {
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                echo '=== 1. Checkout (develop) ==='
                checkout scm
            }
        }

        stage('Build & Deploy') {
            when { changeset "frontend/**" }
            steps {
                echo '=== 2. Docker 이미지 빌드 및 컨테이너 재배포 ==='
                script {
                    try {
                        sh "docker compose -f ${COMPOSE_FILE} up -d --build ${SERVICE_NAME}"
                        echo "✅ ${SERVICE_NAME} 배포 완료"
                    } catch (Exception e) {
                        echo "❌ 배포 실패"
                        throw e
                    }
                }
            }
        }
        stage('Cleanup') {
            steps {
                echo '=== 3. 미사용 이미지 정리 ==='
                sh 'docker image prune -f'
            }
        }
    }

    post {
        success {
            script {
                def author  = sh(script: "git show -s --pretty=%an", returnStdout: true).trim()
                def message = sh(script: "git show -s --pretty=%s",  returnStdout: true).trim()
                def branch  = env.BRANCH_NAME ?: env.GIT_BRANCH

                def msg = "#### ✌️🥳✌️ [Dev] 프론트엔드 배포 성공! ✌️🥳✌️\n" +
                        "**프로젝트:** ${env.JOB_NAME}\n" +
                        "**빌드 번호:** #${env.BUILD_NUMBER}\n" +
                        "**브랜치:** `${branch}`\n" +
                        "**작성자:** ${author}\n" +
                        "**커밋:** ${message}\n" +
                        "**시간:** ${currentBuild.durationString}\n\n" +
                        "[🔗 Jenkins 로그 확인](${env.BUILD_URL})"

                mattermostSend(
                    color: "#0004ff",
                    message: msg,
                    channel: "cicde107",
                    endpoint: "https://meeting.ssafy.com/hooks/m65y6xf4rbrj5f4d15qcmetpza"
                )
            }
        }
        failure {
            script {
                // 1. 전체 로그를 1만 줄까지 긁어와서 txt 파일로 저장
                def fullLogs = currentBuild.rawBuild.getLog(10000).join("\n")
                writeFile file: 'error_log.txt', text: fullLogs
                
                // 2. 젠킨스에 txt 파일을 보관 (Artifact)
                archiveArtifacts artifacts: 'error_log.txt', allowEmptyArchive: true

                def author  = sh(script: "git show -s --pretty=%an", returnStdout: true).trim()
                def message = sh(script: "git show -s --pretty=%s",  returnStdout: true).trim()
                def branch  = env.BRANCH_NAME ?: env.GIT_BRANCH
                
                // 3. 메시지용으로는 에러의 핵심이 담길 확률이 높은 마지막 70줄을 추출
                def shortLogs = currentBuild.rawBuild.getLog(70).join("\n")

                def msg = "#### ☠️💀☠️ [Dev] 프론트엔드 배포 실패! ☠️💀☠️\n" +
                        "**프로젝트:** ${env.JOB_NAME}\n" +
                        "**빌드 번호:** #${env.BUILD_NUMBER}\n" +
                        "**브랜치:** `${branch}`\n" +
                        "**🚨 범인(작성자):** **${author}** (직접 로그를 확인하고 수정하세요!)\n" +
                        "**커밋:** ${message}\n\n" +
                        "### 📥 [전체 에러 로그 다운로드 (클릭)](${env.BUILD_URL}artifact/error_log.txt)\n\n" +
                        "### 📜 핵심 에러 요약\n" +
                        "```text\n${shortLogs}\n```"

                mattermostSend(
                    color: "#ff0000",
                    message: msg,
                    channel: "cicde107",
                    endpoint: "https://meeting.ssafy.com/hooks/m65y6xf4rbrj5f4d15qcmetpza"
                )
            }
        }
    }
}
